# =============================================================
# Medixus OS - 環境変数テンプレート
# このファイルをコピーして .env.local を作成してください
# cp .env.example .env.local
# =============================================================

# --- アプリ設定 ---
NEXT_PUBLIC_APP_ENV=production        # demo | staging | production
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
NEXT_PUBLIC_DEMO_BANNER=false

# --- Supabase（必須）---
# Supabase ダッシュボード > Settings > API から取得
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Anthropic / Claude AI（必須）---
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Twilio（ビデオ通話に必須）---
# https://console.twilio.com > Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# https://console.twilio.com > API Keys
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Stripe（決済に必須）---
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_YOUR_STRIPE_SECRET_KEY_HERE
STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_STRIPE_PUBLISHABLE_KEY_HERE
# Stripe Webhook シークレット（Webhook設定後に取得）
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- 暗号化キー（患者PII暗号化に必須）---
# 生成方法: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- AI電話受付連携（medixus-ai-phone との連携）---
# medixus-ai-phone から通話結果をこのURLにPOSTする
# 例: https://your-domain.vercel.app/api/phone/incoming
MEDIXUS_PHONE_WEBHOOK_URL=https://your-domain.vercel.app/api/phone/incoming
# Webhookの認証トークン（任意だが推奨）
MEDIXUS_PHONE_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- メール通知（任意）---
# Resend: https://resend.com
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# RESEND_FROM_EMAIL=noreply@your-domain.com

# --- ログ・モニタリング（任意）---
# Sentry: https://sentry.io
# SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@sentry.io/xxxxxxx
